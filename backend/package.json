{
  "name": "taskflow-backend",
  "version": "1.0.0",
  "description": "TaskFlow - Task Management API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:up": "node --loader tsx ./scripts/migrate.ts up",
    "migrate:down": "node --loader tsx ./scripts/migrate.ts down",
    "seed": "node --loader tsx ./scripts/seed.ts",
    "test": "vitest",
    "test:integration": "vitest --run"
  },
  "keywords": ["express", "typescript", "postgresql"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "pino": "^8.17.2",
    "pino-http": "^8.5.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.3",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0"
  }
}
